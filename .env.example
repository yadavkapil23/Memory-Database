# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=text-embedding-3-large

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=episodic_memories

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory_system

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Memory Settings
WORKING_MEMORY_MAX_TOKENS=128000
EMBEDDING_CACHE_TTL=86400

# Importance Scoring Weights
NOVELTY_WEIGHT=0.20
TASK_SUCCESS_WEIGHT=0.30
RETRIEVAL_FREQUENCY_WEIGHT=0.25
USER_SIGNAL_WEIGHT=0.15
EMOTIONAL_SALIENCE_WEIGHT=0.10

# Forgetting Curve
HIGH_IMPORTANCE_THRESHOLD=0.7
MEDIUM_IMPORTANCE_THRESHOLD=0.4
HIGH_IMPORTANCE_LAMBDA=0.1
MEDIUM_IMPORTANCE_LAMBDA=0.5
LOW_IMPORTANCE_LAMBDA=1.5
DELETION_THRESHOLD=0.05

# Retrieval
DEFAULT_TOP_K=5
RETRIEVAL_IMPORTANCE_FILTER=0.3

# Logging
LOG_LEVEL=INFO
